# Ön yüz (Vite): http://localhost:5173  —  API: http://localhost:4000
# Tarayıcı: npm run open:site | npm run open:api
# Port kullanımda / localhost yanlış sekme: npm run ports:free  ardından npm run dev:all  (veya tek seferde: npm run dev:fresh)
#
# Calistirma: npm run dev (API :4000 + Vite; eski: npm run dev:all — ayni komut).
# Sadece on yuz: npm run dev:vite. Yalniz API: npm run dev:api. Panel 404: 4000'i baska surec kullaniyor olabilir -- o Node'u kapatip dev tekrar.

API_PORT=4000
NODE_ENV=development

# Yönetim paneli (tek hesap). Oturum jetonu imzası için güçlü bir ADMIN_SESSION_SECRET kullanın.
ADMIN_EMAIL=gozluk@gmail.com
ADMIN_PASSWORD=guclu_bir_sifre
ADMIN_SESSION_SECRET=en_az_32_karakter_rastgele_uzun_metin

# CORS: tarayıcıdan APIye istek (Vite dışı bir origin kullanıyorsanız ekleyin, virgülle ayırın).
# FRONTEND_ORIGIN=https://siteniz.com

# CSRF imzası (boş bırakırsanız ADMIN_SESSION_SECRET veya DATABASE_URL türevi kullanılır).
# CSRF_SECRET=en_az_32_karakter_rastgele

DATABASE_URL=postgresql://postgres:password@localhost:5432/gozluk_sitesi
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=your_email@gmail.com

# Geliştirme: Boş bırakın → tarayıcı /api kullanır, Vite proxy 4000'e yönlendirir.
# Mutlaka tam adres kullanacaksanız sonunda /api olmalı; yalnızca kök verirseniz (örn. http://127.0.0.1:4000) istemci otomatik /api ekler.
# VITE_API_URL=http://127.0.0.1:4000
